---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latestPost = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <div class="welcome">
        <h1>Bem-vindo ao meu blog! 👋</h1>
        <p>Olá, sou Vanessa Amancio, engenheira de software backend. Aqui compartilho minha evolução na programação, estudos, projetos, e comunidade tech. 💻</p>
      </div>

      <hr />

      <section class="latest-post">
        <h2>post recente</h2>
        <a href={`/blog/${latestPost.slug}`} class="post-card">
          {latestPost.data.heroImage && (
            <img
              class="post-cover"
              src={latestPost.data.heroImage}
              alt={latestPost.data.title}
            />
          )}
          <p class="post-date">
            {new Date(latestPost.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
          </p>
          <p class="post-title">{latestPost.data.title}</p>
          <p class="post-summary">{latestPost.data.description}</p>
        </a>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  .welcome {
    margin-bottom: 2.5rem;
  }

  .welcome h1 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    text-transform: none;
    color: var(--text);
  }

  .welcome p {
    color: var(--muted);
    font-size: 15px;
    margin: 0;
  }

  .latest-post {
    margin-top: 2.5rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    margin-top: 1.25rem;
  }

  .post-card:hover .post-title {
    color: var(--accent2);
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin-bottom: 1rem;
    display: block;
    transition: opacity 0.2s;
  }

  .post-card:hover .post-cover {
    opacity: 0.85;
  }

  .post-date {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.35;
    transition: color 0.2s;
    text-transform: none;
    letter-spacing: normal;
  }

  .post-summary {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }
</style>
